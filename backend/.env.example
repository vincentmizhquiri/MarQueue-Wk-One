# =====================================================================
# MarQueue-wk-one  ·  .env.example
# =====================================================================
# Copy this file to ".env" and fill in REAL values when you connect a
# real backend. The real ".env" is gitignored, so secrets never reach
# GitHub. This .example file lists the NAMES only — never paste real
# keys here.
#
#   cp .env.example .env
#
# The browser demo does NOT need any of these — it runs fully offline.
# These are only for the next step (real Supabase/Postgres backend).
# =====================================================================

# --- Supabase (used in production for Auth + storage + Postgres) ---
SUPABASE_URL=your-project-url-here
SUPABASE_ANON_KEY=your-public-anon-key-here

# IMPORTANT: the service-role key is a SERVER-ONLY secret.
# Never expose it in front-end code and never commit it.
SUPABASE_SERVICE_ROLE_KEY=server-only-never-commit

# --- Direct Postgres connection (if you self-host instead of Supabase) ---
DATABASE_URL=postgres://user:password@localhost:5432/marqueue
